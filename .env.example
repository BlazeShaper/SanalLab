# ========================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ========================================
# NOT: Production ortamında Docker Secret'ları
# veya HashiCorp Vault kullanılmalıdır.
# ========================================

ENVIRONMENT=development
DEBUG=True

# JWT AUTHENTICATION
# production'da `openssl rand -hex 32` ile rastgele üretin
JWT_SECRET_KEY=dev_secret_key_1234567890abcdef
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF PROTECTION
CSRF_SECRET=dev_csrf_secret_987654321

# EXTERNAL KURUM API
EXTERNAL_API_URL=https://kurum-api.gov.tr/v1
EXTERNAL_API_KEY=test_api_key_123
EXTERNAL_API_TIMEOUT=5.0

# DATABASE
POSTGRES_USER=sanal_lab_user
POSTGRES_PASSWORD=sanal_lab_dev_pass
POSTGRES_DB=sanal_lab_db

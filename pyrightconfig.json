{
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.13",
  "typeCheckingMode": "basic",
  "include": [
    ".",
    "app",
    "tests"
  ],
  "exclude": [
    ".venv",
    ".venv_new",
    "**/__pycache__"
  ],
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "."
      ]
    }
  ],
  "reportMissingModuleSource": "none"
}
# PostgreSQL Database Credentials
POSTGRES_USER=physicsuser
POSTGRES_PASSWORD=physicspassword
POSTGRES_DB=physicsdb

# The URL that SQLAlchemy will use to connect to the database.
# For Docker Compose, the host is 'db'. For local SQLite, leave this commented out.
DATABASE_URL=postgresql://physicsuser:physicspassword@db:5432/physicsdb
